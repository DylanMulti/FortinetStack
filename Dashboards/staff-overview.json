    {
      "id": 7,
      "title": "Data Downloaded per Device",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (srcname) (fortigate_bytes_received_1h))",
          "instant": true,
          "legendFormat": "{{srcname}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "displayName": "${__field.labels.srcname}"
        }
      }
    },
    {
      "id": 8,
      "title": "Data Uploaded per Device",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
