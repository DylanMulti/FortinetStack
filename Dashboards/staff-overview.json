      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "mode": "continuous-BlPu"
          },
          "displayName": "${__field.labels.srcname}"
        }
      }
    },
    {
      "id": 9,
      "title": "Top Apps by Data Usage",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(topk(10, sum by (app) (fortigate_bytes_received_1h)))",
          "instant": true,
          "legendFormat": "{{app}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "displayName": "${__field.labels.app}"
        }
      }
    },
    {
      "id": 10,
