    {
      "id": 5,
      "title": "P2P Detected",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "bffl0m5t9eoe8e"
      },
      "targets": [
