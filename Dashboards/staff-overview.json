          },
          "expr": "sort_desc(sum by (appcat) (fortigate_bytes_received_1h))",
          "instant": true,
          "legendFormat": "{{appcat}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "displayName": "${__field.labels.appcat}"
        }
      }
    },
    {
      "id": 11,
      "title": "Device Activity Timeline",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
