{
  "title": "Staff Usage Overview",
  "uid": "staff-overview-v2",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "1m",
  "time": {
    "from": "now-8h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Connected Devices",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "bffl0m5t9eoe8e"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "bffl0m5t9eoe8e"
          },
          "expr": "count(sum by (srcmac) (count_over_time({job=\"fortigate\"} | logfmt | srcmac != \"\" [8h])))",
          "queryType": "range",
          "instant": true,
          "legendFormat": "Devices"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "displayName": "Connected Devices"
        }
      }
    },
    {
      "id": 2,
      "title": "Total Data Downloaded",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum(fortigate_bytes_received_1h)",
          "instant": true,
          "legendFormat": "Total"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "displayName": "Total Downloaded"
        }
      }
    },
