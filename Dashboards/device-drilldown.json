{
  "title": "Device Drill Down",
  "uid": "device-drilldown-v2",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "1m",
  "time": {
    "from": "now-8h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "srcname",
        "label": "Device Name",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "effl0nh8i0c8we"
        },
        "query": "label_values(fortigate_bytes_received_1h, srcname)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Downloaded",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum(fortigate_bytes_received_1h{srcname=~\"$srcname\"})",
          "instant": true,
          "legendFormat": "Downloaded"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "displayName": "Total Downloaded"
        }
      }
    },
    {
      "id": 2,
      "title": "Total Uploaded",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum(fortigate_bytes_sent_1h{srcname=~\"$srcname\"})",
          "instant": true,
          "legendFormat": "Uploaded"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "displayName": "Total Uploaded"
        }
      }
    },
    {
      "id": 3,
      "title": "Total Sessions",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum(fortigate_sessions_1h{srcname=~\"$srcname\"})",
          "instant": true,
          "legendFormat": "Sessions"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "semi-dark-blue",
            "mode": "fixed"
          },
          "displayName": "Total Sessions"
        }
      }
    },
    {
      "id": 4,
      "title": "Social Media Sessions",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum(fortigate_sessions_1h{srcname=~\"$srcname\",appcat=\"Social.Media\"}) or vector(0)",
          "instant": true,
          "legendFormat": "Sessions"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "displayName": "Social Media Sessions"
        }
      }
    },
    {
      "id": 5,
      "title": "Download Rate Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum by (appcat) (rate(fortigate_bytes_received_total{srcname=~\"$srcname\"}[5m]))",
          "legendFormat": "{{appcat}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "displayName": "${__field.labels.appcat}"
        }
      }
    },
    {
      "id": 6,
      "title": "Data Downloaded per App",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (app) (fortigate_bytes_received_1h{srcname=~\"$srcname\"}))",
          "instant": true,
          "legendFormat": "{{app}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "displayName": "${__field.labels.app}"
        }
      }
    },
    {
      "id": 7,
      "title": "App Category Breakdown",
      "type": "piechart",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (appcat) (fortigate_bytes_received_1h{srcname=~\"$srcname\"}))",
          "instant": true,
          "legendFormat": "{{appcat}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "displayName": "${__field.labels.appcat}"
        }
      }
    },
    {
      "id": 8,
      "title": "Social Media & Streaming Detail",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sum by (app) (rate(fortigate_bytes_received_total{srcname=~\"$srcname\", app=~\"Facebook|TikTok|YouTube|Instagram|Netflix|Twitter|Snapchat|WhatsApp|Spotify|Pinterest\"}[5m]))",
          "legendFormat": "{{app}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "displayName": "${__field.labels.app}"
        }
      }
    },
    {
      "id": 9,
      "title": "Full App Usage Table",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "effl0nh8i0c8we"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (app, appcat) (fortigate_bytes_received_1h{srcname=~\"$srcname\"}))",
          "instant": true,
          "legendFormat": "{{app}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (app, appcat) (fortigate_bytes_sent_1h{srcname=~\"$srcname\"}))",
          "instant": true,
          "legendFormat": "{{app}}"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "effl0nh8i0c8we"
          },
          "expr": "sort_desc(sum by (app, appcat) (fortigate_sessions_1h{srcname=~\"$srcname\"}))",
          "instant": true,
          "legendFormat": "{{app}}"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "app": "Application",
              "appcat": "Category",
              "Value #A": "Downloaded",
              "Value #B": "Uploaded",
              "Value #C": "Sessions"
            },
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "srcname": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "displayName": "Downloaded",
                "desc": true
              }
            ]
          }
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "minWidth": 130
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Downloaded"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uploaded"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Sessions"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-blues"
                }
              }
            ]
          }
        ]
      }
    }
  ]
}